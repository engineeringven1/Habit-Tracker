# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Current Supabase project
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Old Supabase project (only needed for migrate_data.dart)
OLD_SUPABASE_URL=your_old_supabase_url_here
OLD_SUPABASE_SERVICE_KEY=your_old_supabase_service_key_here

# Tool scripts
SUPABASE_USER_ID=your_user_id_here
MIGRATE_EMAIL=your_email_here
MIGRATE_PASSWORD=your_password_here
